def ensure_doc():
    doc = App.ActiveDocument
    if doc is None:
        raise Exception("No active document.")
    return doc


def parse_float_list(text, fallback):
    text = (text or "").strip()
    if not text:
        return list(fallback)
    vals = []
    for part in text.split(","):
        part = part.strip()
        if not part:
            continue
        vals.append(float(part))
    return vals if vals else list(fallback)


